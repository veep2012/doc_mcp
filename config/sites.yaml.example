sites:

  # ---------------------------------------------------------------------------
  # Authenticated site (headful — user logs in manually in browser)
  # ---------------------------------------------------------------------------
  - name: "My Private Docs"
    url: "https://docs.example.com"
    auth_required: true
    auth_type: "magic_link"         # email_code | magic_link | password_only
    auth_mode: "headful"            # headful: visible browser, user logs in manually
    username: "${SITE1_USERNAME}"   # set in .env
    password: "${SITE1_PASSWORD}"   # set in .env (if needed)
    session_file: "storage/my_private_docs.json"
    crawl:
      start_url: "https://docs.example.com/documentation"
      max_depth: 5
      delay_seconds: 1.0
      start_delay_seconds: 10.0
      respect_robots_txt: true
      block_images: true            # skip image/font/media requests to speed up crawling
      redirect_policy: final        # final | requested | skip
      ignore_query_links: true      # skip discovered links that contain a query string
      ignore_anchor_links: true     # skip links that only differ by #fragment
      ignore_https_errors: false    # set true for sites with bad/mismatched TLS certs
      allow_patterns: []            # e.g. ["https://docs.example.com/documentation/*"]
      deny_patterns: []             # e.g. ["*/changelog/*", "*/print/*"]
    index_file: "index/my_private_docs.db"
    search_engine: "hybrid"         # hybrid | keyword | vector
    vector_index_file: "index/my_private_docs.vec.db"
    vectorizer:
      chunk_size: 800
      chunk_overlap: 120
      embedding_model: "BAAI/bge-small-en-v1.5"  # English-focused default; use sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 for multilingual search

  # ---------------------------------------------------------------------------
  # Public site (no auth required)
  # ---------------------------------------------------------------------------
  - name: "My Public Docs"
    url: "https://public-docs.example.com/"
    auth_required: false
    session_file: null
    crawl:
      start_url: "https://public-docs.example.com/"
      max_depth: 3
      delay_seconds: 0.5
      start_delay_seconds: 0.0
      respect_robots_txt: true
      block_images: true
      redirect_policy: final
      ignore_query_links: true
      ignore_anchor_links: true
      ignore_https_errors: false
      allow_patterns: []
      deny_patterns: ["https://public-docs.example.com/auth/*"]
    index_file: "index/my_public_docs.db"
    search_engine: "vector"         # vector-only semantic search; requires a vector sidecar
    vector_index_file: "index/my_public_docs.vec.db"
    vectorizer:
      chunk_size: 800
      chunk_overlap: 120
      embedding_model: "BAAI/bge-small-en-v1.5"  # English-focused default; use sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 for multilingual search
