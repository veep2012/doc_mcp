# =============================================================================
# Proxy Settings (corporate network)
# =============================================================================
#HTTPS_PROXY=http://your-proxy-host:port
#HTTP_PROXY=http://your-proxy-host:port

# =============================================================================
# MCP Server Settings
# =============================================================================
MCP_SERVER_NAME=docs-mcp
MCP_LOG_LEVEL=INFO

# =============================================================================
# Development Environment Paths
# =============================================================================
# Optional override used by docs and smoke-test helpers when a virtual
# environment directory other than .venv is preferred.
DOC_MCP_VENV=.venv

# =============================================================================
# Auth Settings (used for automated auth mode)
# Per-site credentials — add one block per site
# =============================================================================
# Site 1 example
SITE1_USERNAME=your-email@example.com
SITE1_PASSWORD=your-password

# =============================================================================
# Crawl Settings
# =============================================================================
# Current runtime reads crawl behavior from config/sites.yaml, not from these
# example variables. Keep them only if you want local placeholders for scripts.
CRAWL_DELAY_SECONDS=1.0
CRAWL_MAX_CONCURRENT=3
CRAWL_RESPECT_ROBOTS_TXT=true

# =============================================================================
# Storage Paths (relative to project root)
# =============================================================================
# Current runtime resolves session_file and index_file from config/sites.yaml.
STORAGE_DIR=storage
INDEX_DIR=index
CONFIG_FILE=config/sites.yaml
